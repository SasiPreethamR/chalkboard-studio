# Copy needed values into your shell env (or a local .env loader) before signed release builds.
# Apple Developer account email
APPLE_ID=you@example.com

# App-specific password generated for your Apple ID
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Apple Developer Team ID (10 characters)
APPLE_TEAM_ID=ABCDE12345

# Optional: force an explicit signing identity name
# CSC_NAME=Developer ID Application: Your Name (ABCDE12345)
